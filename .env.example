# MongoDB Atlas connection string (include the database name in the path)
MONGODB_URI=mongodb+srv://user:password@cluster0.mongodb.net/paramatma

# Admin login password for /admin
ADMIN_PASSWORD=change-me

# Random 32+ character secret used to sign the admin session cookie
# Generate one with: openssl rand -base64 32
SESSION_SECRET=

# Public site URL, used for metadata, OG images, and sitemap generation
NEXT_PUBLIC_SITE_URL=http://localhost:3000
